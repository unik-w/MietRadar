# =============================================================================
# IMMO BOT - Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git!
# =============================================================================

# --- wg-gesucht.de credentials ---
WG_EMAIL=your_email@example.com
WG_PASSWORD=your_password_here

# --- immobilienscout24.de credentials ---
IMMO_EMAIL=your_immo_email@example.com
IMMO_PASSWORD=your_immo_password_here

# --- Personal details (for IS24 contact form auto-fill) ---
IMMO_SALUTATION=Herr
IMMO_FIRST_NAME=Max
IMMO_LAST_NAME=Mustermann
IMMO_PHONE=
IMMO_STREET=Musterstraße
IMMO_HOUSE_NUMBER=1
IMMO_POSTCODE=80333
IMMO_CITY=München

# --- Search URLs (comma-separated if multiple) ---
# WG-Gesucht: go to the website, apply your filters, sort by newest, and paste the URL here.
WG_SEARCH_URLS=https://www.wg-gesucht.de/1-zimmer-wohnungen-und-wohnungen-in-Muenchen.90.1+2.1.0.html?offer_filter=1&city_id=90&sort_order=0&noDeact=1&categories[]=1&categories[]=2&rent_types[]=0&sMin=25&rMax=1500

# ImmobilienScout24: go to IS24, apply your filters, and paste the URL here.
IMMO_SEARCH_URLS=https://www.immobilienscout24.de/Suche/de/bayern/muenchen/wohnung-mieten

# --- Bot settings ---
# How often to check for new offers (in seconds)
CHECK_INTERVAL_SECONDS=60

# --- LLM personalisation (Gemma 3 1B via PyTorch + Apple Metal MPS) ---
# Set to true to enable AI-personalised messages using the listing description.
USE_LLM_PERSONALIZATION=false

# Max characters of the WG-Gesucht advert description to feed to the LLM.
# Default is 1200. Reduce if you run out of context/memory, or increase if you want more context.
LLM_MAX_DESC_CHARS=1200

# HuggingFace token — needed to download the Gemma 3 model weights on first run.
# Get yours at https://huggingface.co/settings/tokens
# Then accept the Gemma 3 licence at: https://huggingface.co/google/gemma-3-1b-it
HF_TOKEN=your_huggingface_token_here

# If you hit MPS ops not implemented:
# export PYTORCH_ENABLE_MPS_FALLBACK=1
